# Engine — service-specific overrides
# Shared variables live in the repo root .env.example — run `npm run env:sync`
# from the repo root after editing .env.

# Server (required)
PORT=3005

# --- Required (synced from root .env) --------------------------------------
# DATABASE_URL
# ENGINE_ADMIN_KEY
# ENGINE_ACCESS_KEYS
# WALLET_ENCRYPTION_KEY
# SESSION_JWT_SECRET
# CHAIN_<id>_RPC_URL / CHAIN_<id>_NAME

# --- Optional (Engine-only) -------------------------------------------------

NODE_ENV=development

# Transaction worker
TX_WORKER_POLL_INTERVAL_MS=2000
TX_WORKER_MAX_RETRIES=3
TX_CONFIRMATION_TIMEOUT_MS=120000
NONCE_RECONCILE_INTERVAL_MS=30000

# Webhooks
WEBHOOK_URL=
WEBHOOK_SECRET=
WEBHOOK_WORKER_POLL_INTERVAL_MS=5000
WEBHOOK_WORKER_BATCH_SIZE=20

# Connect / SIWE local dev — log email OTP codes to console
ENGINE_AUTH_DEV_LOG_OTP=true
SESSION_JWT_TTL_SECONDS=604800

# Bridge (CDP)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Licensing (optional)
# LICENSE_SERVER_URL
# LICENSE_KEY
# LICENSE_PRODUCT
# LICENSE_POLL_INTERVAL_MS
# LICENSE_INSTANCE_ID

# Rate limiting (defaults synced from root; override per instance if needed)
DEFAULT_API_KEY_RATE_LIMIT_PER_MINUTE=120
GLOBAL_IP_RATE_LIMIT_PER_MINUTE=600
