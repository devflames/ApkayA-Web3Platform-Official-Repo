# Server
PORT=3005
NODE_ENV=development
LOG_LEVEL=info

# Auth — clients must send `Authorization: Bearer <key>`
#
# ENGINE_ADMIN_KEY: the master key. Required for /api-key/* endpoints only
# (creating and revoking customer API keys). Never distribute this key —
# generate with: openssl rand -hex 32
ENGINE_ADMIN_KEY=

# ENGINE_ACCESS_KEYS: legacy static allowlist, checked as a fallback after
# the database-backed api_keys table. Useful for bootstrapping before you've
# issued any real keys via `apkaya apikey create` / POST /api-key/create.
# Comma-separated. Safe to leave empty once you're issuing DB-backed keys.
ENGINE_ACCESS_KEYS=dev-secret-key-change-me

# Database — Postgres (required). Run apps/engine/scripts/setup-postgres.ps1 first
# on native installs, or `docker compose up postgres -d` from the repo root.
# Do not use DATABASE_PATH (SQLite removed in Phase 1).
DATABASE_URL=postgres://apkaya:apkaya@localhost:5432/engine

# Wallet encryption — backend wallet private keys are encrypted at rest
# with this key (AES-256-GCM). Generate with: openssl rand -hex 32
WALLET_ENCRYPTION_KEY=

# Chains — add one block per chain you want to support.
# CHAIN_<ID>_RPC_URL and CHAIN_<ID>_NAME
CHAIN_80002_RPC_URL=https://rpc-amoy.polygon.technology
CHAIN_80002_NAME=Polygon Amoy Testnet

CHAIN_11155111_RPC_URL=https://rpc.sepolia.org
CHAIN_11155111_NAME=Ethereum Sepolia

# Transaction worker tuning
TX_WORKER_POLL_INTERVAL_MS=2000
TX_WORKER_MAX_RETRIES=3
TX_CONFIRMATION_TIMEOUT_MS=120000

# Per-wallet nonce manager — how often each worker reconciles in-memory
# nonces against the chain pending count (milliseconds).
NONCE_RECONCILE_INTERVAL_MS=30000

# Webhooks (optional) — fired on tx.sent / tx.mined / tx.reverted / tx.errored
WEBHOOK_URL=
WEBHOOK_SECRET=
WEBHOOK_WORKER_POLL_INTERVAL_MS=5000
WEBHOOK_WORKER_BATCH_SIZE=20

# Rate limiting — per customer API key (see api_keys.rate_limit_per_minute)
DEFAULT_API_KEY_RATE_LIMIT_PER_MINUTE=120
GLOBAL_IP_RATE_LIMIT_PER_MINUTE=600

# End-user auth (Connect / SIWE / email OTP) — separate from API-key auth
SESSION_JWT_SECRET=
SESSION_JWT_TTL_SECONDS=604800
# Local dev: log OTP codes to console instead of sending email
ENGINE_AUTH_DEV_LOG_OTP=true
