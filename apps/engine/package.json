{
  "name": "@apkaya/engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./platform": "./dist/platform/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "worker": "tsx watch src/workers/txWorker.ts",
    "webhook-worker": "tsx watch src/workers/webhookWorker.ts",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
  "@solana/spl-token": "^0.4.13",
    "ethers": "^6.13.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "@coinbase/cdp-sdk": "^1.21.0",
    "helmet": "^7.1.0",
    "nanoid": "^5.0.7",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.13.1",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
