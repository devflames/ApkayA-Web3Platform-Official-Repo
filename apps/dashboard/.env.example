# Dashboard — Vite client env (browser-facing URLs only)
# Shared API key default is synced from root .env via `npm run env:sync`.
# Secrets never belong here — VITE_* vars are embedded in the client bundle.

VITE_ENGINE_URL=http://localhost:3005
VITE_INSIGHT_URL=http://localhost:3006
VITE_DEFAULT_API_KEY=dev-secret-key-change-me
