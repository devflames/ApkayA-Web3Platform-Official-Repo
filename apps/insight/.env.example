# Insight — service-specific overrides
# Shared variables live in the repo root .env.example — run `npm run env:sync`
# from the repo root after editing .env.

# Server (required)
PORT=3006

# --- Required (synced from root .env) --------------------------------------
# DATABASE_URL
# ENGINE_ACCESS_KEYS
# CHAIN_<id>_RPC_URL / CHAIN_<id>_NAME

# --- Optional (Insight-only indexer tuning) ---------------------------------

NODE_ENV=development

INSIGHT_POLL_INTERVAL_MS=5000
INSIGHT_BLOCK_CHUNK=2000
INSIGHT_CONFIRMATIONS=3
INSIGHT_REORG_CHECK_DEPTH=64
INSIGHT_BOOTSTRAP_LOOKBACK=10000
# INSIGHT_START_BLOCK=0
# CHAIN_80002_INSIGHT_START_BLOCK=12345678

# Rate limiting (defaults synced from root)
DEFAULT_API_KEY_RATE_LIMIT_PER_MINUTE=120
GLOBAL_IP_RATE_LIMIT_PER_MINUTE=600
