# Server
PORT=3006
NODE_ENV=development
LOG_LEVEL=info

# Auth — same customer API keys as Engine (shared api_keys table).
# Set ENGINE_ACCESS_KEYS as a legacy fallback if needed.
ENGINE_ACCESS_KEYS=dev-secret-key-change-me

# Database — same Postgres instance as Engine
DATABASE_URL=postgres://apkaya:apkaya@localhost:5432/engine

# Chains — reuse Engine's CHAIN_<id>_RPC_URL / CHAIN_<id>_NAME pattern
CHAIN_80002_RPC_URL=https://rpc-amoy.polygon.technology
CHAIN_80002_NAME=Polygon Amoy Testnet

CHAIN_11155111_RPC_URL=https://rpc.sepolia.org
CHAIN_11155111_NAME=Ethereum Sepolia

# Indexer tuning
INSIGHT_POLL_INTERVAL_MS=5000
INSIGHT_BLOCK_CHUNK=2000
INSIGHT_CONFIRMATIONS=3
INSIGHT_REORG_CHECK_DEPTH=64
INSIGHT_BOOTSTRAP_LOOKBACK=10000
# INSIGHT_START_BLOCK=0
# CHAIN_80002_INSIGHT_START_BLOCK=12345678

# Rate limiting (shared defaults with Engine)
DEFAULT_API_KEY_RATE_LIMIT_PER_MINUTE=120
GLOBAL_IP_RATE_LIMIT_PER_MINUTE=600
