# Contract deploy scripts (Hardhat)
# Shared chain RPC URLs and deployer key are synced from root .env via
# `npm run env:sync`.

# Required for deploy:amoy / deploy:sepolia / deploy:token
DEPLOYER_PRIVATE_KEY=

# Synced from root (optional — auto-register with Engine after deploy)
CHAIN_80002_RPC_URL=https://rpc-amoy.polygon.technology
CHAIN_11155111_RPC_URL=https://rpc.sepolia.org
ENGINE_URL=http://localhost:3005
ENGINE_API_KEY=dev-secret-key-change-me
