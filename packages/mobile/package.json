{
  "name": "@apkaya/mobile-sdk",
  "version": "0.1.0",
  "description": "React Native SDK for ApkayA — wraps @apkaya/sdk and @apkaya/connect with mobile adapters",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-keychain": ">=8.0.0",
    "@walletconnect/react-native-compat": ">=2.0.0"
  },
  "dependencies": {
    "@apkaya/connect": "*",
    "@apkaya/sdk": "*",
    "@walletconnect/universal-provider": "^2.17.3",
    "ethers": "^6.13.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "typescript": "^5.5.4"
  }
}
