{
  "name": "@apkaya/bridge",
  "version": "0.1.0",
  "description": "Buy, swap, and checkout widgets powered by Coinbase Developer Platform via Engine",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./styles.css": {
      "default": "./dist/react/bridge.css"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-css.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@apkaya/connect": "*"
  },
  "dependencies": {
    "ethers": "^6.13.2"
  },
  "devDependencies": {
    "@apkaya/connect": "*",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.4"
  }
}
