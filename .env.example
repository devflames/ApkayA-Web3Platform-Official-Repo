# =============================================================================
# ApkayA Web3Platform — shared environment (copy to .env at repo root)
# =============================================================================
# Run `npm run env:sync` after editing this file to propagate values into
# apps/engine/.env, apps/insight/.env, apps/dashboard/.env, and
# packages/contracts/.env.
#
# Generate secrets (recommended for anything beyond local dev):
#   openssl rand -hex 32
# =============================================================================

# --- Required (local dev defaults below; change for production) -----------

# Postgres — used by Engine and Insight
DATABASE_URL=postgres://apkaya:apkaya@localhost:5432/engine

# Engine admin key — /api-key/* only (create/revoke customer keys)
ENGINE_ADMIN_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Customer API key fallback — also used by dashboard + QUICKSTART curl examples
ENGINE_ACCESS_KEYS=dev-secret-key-change-me

# Encrypts backend wallet private keys at rest (Engine) — must be 64 hex chars
WALLET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# End-user session JWT signing (Engine Connect / SIWE)
SESSION_JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Chains (Engine + Insight + contract deploys) -------------------------

CHAIN_80002_RPC_URL=https://rpc-amoy.polygon.technology
CHAIN_80002_NAME=Polygon Amoy Testnet

CHAIN_11155111_RPC_URL=https://rpc.sepolia.org
CHAIN_11155111_NAME=Ethereum Sepolia

# Solana (optional — Phase 9)
# CHAIN_devnet_FAMILY=solana
# CHAIN_devnet_RPC_URL=https://api.devnet.solana.com
# CHAIN_devnet_NAME=Solana Devnet
# CHAIN_devnet_COMMITMENT=confirmed

# --- Contract deploys (packages/contracts — needs funded testnet wallet) ----

# Private key with testnet native token for deploy scripts (never commit real keys)
DEPLOYER_PRIVATE_KEY=

# Optional: register deploys with Engine automatically (set after env:sync)
ENGINE_URL=http://localhost:3005
ENGINE_API_KEY=dev-secret-key-change-me

# --- Optional integrations --------------------------------------------------

# Coinbase CDP (Engine /bridge — server-only)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Webhooks (Engine — optional)
WEBHOOK_URL=
WEBHOOK_SECRET=

# --- Shared tuning ----------------------------------------------------------

LOG_LEVEL=info
DEFAULT_API_KEY_RATE_LIMIT_PER_MINUTE=120
GLOBAL_IP_RATE_LIMIT_PER_MINUTE=600

# --- Dashboard defaults (browser → localhost services) --------------------

VITE_ENGINE_URL=http://localhost:3005
VITE_INSIGHT_URL=http://localhost:3006
VITE_DEFAULT_API_KEY=dev-secret-key-change-me

# --- Docker Compose overrides (uncomment when using compose service names) --
# DATABASE_URL=postgres://apkaya:apkaya@postgres:5432/engine
# ENGINE_URL=http://engine-api:3005
